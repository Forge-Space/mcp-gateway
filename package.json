{
  "name": "@forgespace/mcp-gateway-client",
  "version": "1.28.2",
  "description": "Forge MCP Gateway client - Connect to your Forge MCP Gateway instance via NPX",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "type": "module",
  "bin": {
    "forge-mcp-gateway": "./build/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.client.json",
    "build:watch": "tsc -p tsconfig.client.json --watch",
    "clean": "rimraf build/ node_modules/.cache/",
    "dev": "tsc -p tsconfig.client.json --watch",
    "lint": "eslint 'src/**/*.ts' --fix",
    "lint:types": "tsc -p tsconfig.client.json --noEmit",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:eslint:fix": "eslint 'src/**/*.ts' --fix",
    "lint:prettier": "prettier --check \"src/**/*.{ts,json}\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "deps:check": "npm-check-updates",
    "deps:update": "npm-check-updates -u && npm install",
    "deps:update:interactive": "npm-check-updates -i",
    "test": "make test",
    "prepare": "npm run build && husky install",
    "precommit": "npm run lint",
    "lint:check": "eslint 'src/**/*.ts'",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check:tenant-decoupling": "bash scripts/security/validate-tenant-decoupling.sh",
    "validate": "npm run lint:check && npm run format:check && npm run test && npm run check:tenant-decoupling",
    "ci:test-autogen:write": "npx forge-ai-init test-autogen --staged --write --json --tenant \"$FORGE_TENANT_ID\" --tenant-profile-ref \"$FORGE_TENANT_PROFILE_REF\"",
    "ci:test-autogen:check": "npx forge-ai-init test-autogen --check --json --tenant \"$FORGE_TENANT_ID\" --tenant-profile-ref \"$FORGE_TENANT_PROFILE_REF\"",
    "pre-commit": "npm run lint && npm run format && npm run test",
    "prepack": "npm run build",
    "release:publish": "npm publish --access public",
    "integrate": "node scripts/integrate.js",
    "integrate:mcp-gateway": "node scripts/integrate.js --project=mcp-gateway",
    "integrate:uiforge-mcp": "node scripts/integrate.js --project=uiforge-mcp",
    "integrate:uiforge-webapp": "node scripts/integrate.js --project=uiforge-webapp"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "forge-mcp-gateway",
    "ai",
    "llm"
  ],
  "author": "Forge MCP Gateway Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Forge-Space/mcp-gateway.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.7",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/fs-extra": "^11.0.1",
    "@types/node": "^25.3.5",
    "@types/semver": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-check-updates": "^17.1.14",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
