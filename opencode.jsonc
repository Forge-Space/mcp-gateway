{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CLAUDE.md"],
  "mcp": {
    "sentry": {
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "**/__pycache__/**",
      "**/.mypy_cache/**",
      "**/.pytest_cache/**",
      "**/htmlcov/**",
      "**/.ruff_cache/**",
      ".serena/**/logs/**"
    ]
  }
}
